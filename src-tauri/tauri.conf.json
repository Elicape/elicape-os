{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop-AI-Coding",
  "version": "0.1.0",
  "identifier": "com.desktop-ai-coding.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop AI Coding",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["default"]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
